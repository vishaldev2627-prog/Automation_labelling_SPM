# Loaded into the backend container by docker-compose.yml (env_file: .env).
# Add optional backend overrides below if you need them (see
# backend/.env.example for the full list) — e.g. CORS_ORIGINS, SAM_DEVICE,
# LOG_LEVEL.

# Host paths bind-mounted into the backend container (used by
# docker-compose.yml, NOT read by the backend app itself).
DATASET_HOST_PATH=./dataset
EXPORTS_HOST_PATH=./exports
MODELS_HOST_PATH=./models
