# Loaded into the backend container by docker-compose.yml (env_file: .env).
# Add optional backend overrides below if you need them (see
# backend/.env.example for the full list) — e.g. CORS_ORIGINS, SAM_DEVICE,
# LOG_LEVEL.
#
# NOTE: the dataset/exports/models host paths are hardcoded directly in
# docker-compose.yml's volumes (not env-var driven) — Coolify does not feed
# its UI-configured env vars into compose's variable-substitution pass, only
# into the running container, so ${VAR}-style bind mount paths silently fall
# back to their defaults under Coolify. Edit docker-compose.yml directly if
# these paths ever need to change.
