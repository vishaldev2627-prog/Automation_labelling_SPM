# Copy this file to .env and adjust values for your machine.

# Dataset location (folder containing images/ and labels/ subfolders)
DATASET_PATH=../dataset
EXPORTS_PATH=../exports

# SAM2
SAM_CHECKPOINT=../models/sam2.1_hiera_large.pt
SAM_MODEL_CFG=sam2.1_hiera_l.yaml
SAM_DEVICE=auto
SAM_USE_ONNX=false
SAM_ONNX_ENCODER_PATH=../models/sam2_encoder.onnx
SAM_ONNX_DECODER_PATH=../models/sam2_decoder.onnx

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Processing
MAX_IMAGE_DIMENSION=4096
THUMBNAIL_MAX_DIMENSION=1024
POLYGON_EPSILON_RATIO=0.002
MIN_POLYGON_POINTS=3
BATCH_MAX_WORKERS=2

# Logging
LOG_LEVEL=INFO
LOG_FILE=../logs/backend.log
